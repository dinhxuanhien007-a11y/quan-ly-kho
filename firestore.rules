rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- CÁC HÀM HELPER ---
    function isOwner() {
      return request.auth.token.role == 'owner';
    }
    function isSignedIn() {
      return request.auth != null;
    }
    // owner luôn có quyền, admin chỉ có quyền nếu custom claim canReconcile == true
    function canReconcile() {
      return isSignedIn() && (
        isOwner() ||
        (request.auth.token.role == 'admin' && request.auth.token.canReconcile == true)
      );
    }
    // Kiểm tra uid hiện tại có trong danh sách participant của phiên kiểm kê cộng tác
    function isParticipant(sessionId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/stocktakes/$(sessionId)).data.participantUids;
    }
    // Kiểm tra phiên kiểm kê chưa bị đóng (chưa adjusted)
    function sessionIsOpen(sessionId) {
      return get(/databases/$(database)/documents/stocktakes/$(sessionId)).data.status != 'adjusted';
    }

    // --- QUẢN LÝ USER ---
    match /allowlist/{email} {
      allow read, write: if isOwner();
    }

    match /users/{userId} {
      allow list: if isOwner(); // Chỉ owner mới được list
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwner());
      allow write: if isOwner();
    }

    // --- DỮ LIỆU CỐT LÕI ---
    match /products/{docId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
    match /partners/{docId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
    match /inventory_lots/{docId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }
    match /product_summaries/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // Chặn ghi từ client, kể cả owner
    }

    // --- PHIẾU NHẬP/XUẤT ---
    match /import_tickets/{ticketId} {
      allow read: if canReconcile();
      allow write: if isOwner();
    }
    match /export_tickets/{ticketId} {
      allow read: if canReconcile();
      allow write: if isOwner();
    }
    
    // --- DỮ LIỆU DASHBOARD ---
    match /dailyActivity/{docId} {
        allow read: if isOwner();
        allow write: if false;
    }
    match /dashboardStats/{docId} {
        allow read: if isOwner();
        allow write: if false;
    }

    // --- CẢNH BÁO & KIỂM KÊ ---
    // Gộp 2 rule cũ thành 1 rule đúng duy nhất
    match /notifications/{notificationId} {
      allow read, write, delete: if isOwner();
    }
    
    match /stocktakes/{sessionId} {
      // Owner toàn quyền
      allow read, write: if isOwner();
      // Admin được đọc và list tất cả stocktakes (để query participantUids)
      allow read, list: if isSignedIn() && request.auth.token.role == 'admin';

      match /items/{itemId} {
        allow read: if isOwner() || (isSignedIn() && request.auth.token.role == 'admin');
        allow write: if isOwner();
      }

      // count_entries: admin participant được đọc/ghi
      match /count_entries/{entryId} {
        allow read: if isOwner() || isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.enteredBy == request.auth.uid;
        allow update: if isOwner() || (
          isSignedIn()
          && request.resource.data.enteredBy == request.auth.uid
        );
        allow delete: if isOwner();
      }

      // audit_logs
      match /audit_logs/{logId} {
        allow read: if isOwner() || isSignedIn();
        allow write: if isOwner() || isSignedIn();
      }
    }
    
    // --- ĐIỀU CHỈNH KHO ---
    match /inventory_adjustments/{adjustmentId} {
      allow read: if isSignedIn();
      allow create: if isOwner();
    }

  } // Đóng match /databases/{database}/documents
}